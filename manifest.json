{
  "manifest_version": 3,
  "name": "Cal Grabr",
  "version": "1.0.0",
  "description": "Select time blocks on Google Calendar and export as formatted bullet points",
  "permissions": [],
  "host_permissions": ["https://calendar.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://calendar.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
